# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY= AIzaSyBnrhCvJi-wqZ8-I-wVHKn-WxnRNuaWa6Q

# Optional: OpenAI API Key (alternative LLM provider)
# OPENAI_API_KEY=your_openai_api_key_here

# FastAPI Backend URL (used by Streamlit UI)
